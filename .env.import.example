# Copy this file to .env.import and fill in your values
# .env.import is git-ignored — never commit it

MSSQL_SERVER=192.168.x.x
MSSQL_PORT=1433
MSSQL_DATABASE=your_database_name
MSSQL_USER=your_sql_username
MSSQL_PASSWORD=your_sql_password

# Column name overrides (fill in after running: node scripts/discover-schema.js)
# These are the EXACT column names from MSSQL (case-sensitive)
STD_COL_PARTNO=
STD_COL_DESCRIPTION=
STD_COL_BRAND_FK=
STD_COL_CATEGORY_FK=
BRAND_COL_ID=
BRAND_COL_NAME=
CATEGORY_COL_ID=
CATEGORY_COL_NAME=
